{
    "name": "susantokun/filament-dynamic-menu",
    "description": "Database-driven dynamic navigation menus for Filament panels with multi-tenancy support.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "filament",
        "dynamic-menu",
        "navigation",
        "laravel",
        "multi-tenant"
    ],
    "authors": [
        {
            "name": "susantokun"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "suggest": {
        "bezhansalleh/filament-shield": "Auto-resolve Shield permissions for menu items (^3.0 || ^4.0)",
        "stancl/tenancy": "Multi-tenancy support (^3.0)"
    },
    "autoload": {
        "psr-4": {
            "Susantokun\\FilamentDynamicMenu\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Susantokun\\FilamentDynamicMenu\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Susantokun\\FilamentDynamicMenu\\FilamentDynamicMenuServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
